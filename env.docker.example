# Copy this file to `.env` (same folder as docker-compose.yml) and edit.
# docker compose reads it automatically for variable substitution.

# --- Database ---
DB_NAME=wanosc_db
DB_USER=wanosc_user
DB_PASS=change_this_password

# --- Auth ---
# Generate: openssl rand -hex 32
JWT_SECRET=change_this_to_a_long_random_string
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_admin_password

# --- CORS ---
# Bearer-token auth is used (not cookies), so "*" is fine. For stricter setups,
# set this to your public origin, e.g. https://your-domain.com
CORS_ORIGINS=*

# --- Web ---
# Host port that maps to the app. Use 80 for http, or e.g. 8080 if 80 is taken.
WEB_PORT=80
