# ============================================================
# backend/.env  — copy to /opt/wanosc/backend/.env and edit
# ============================================================

# --- SQL database ---------------------------------------------------
# PostgreSQL (recommended):
DATABASE_URL="postgresql+psycopg2://wanosc_user:CHANGE_ME@localhost:5432/wanosc_db"
# MySQL alternative:
# DATABASE_URL="mysql+pymysql://wanosc_user:CHANGE_ME@localhost:3306/wanosc_db"
# SQLite fallback (single-file, no server):
# DATABASE_URL="sqlite:////opt/wanosc/backend/app.db"

# --- Auth -----------------------------------------------------------
# Generate a strong secret, e.g.:  python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET="CHANGE_ME_TO_A_LONG_RANDOM_STRING"

# The initial admin account, created automatically on first startup.
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="CHANGE_ME"

# --- CORS -----------------------------------------------------------
# The public URL your frontend is served from (used for browser CORS).
CORS_ORIGINS="https://your-domain.com"

# --- Legacy keys (safe to leave; not used when DATABASE_URL is set) --
MONGO_URL="mongodb://localhost:27017"
DB_NAME="unused"
